{
  "expo": {
    "name": "TakeFive",
    "slug": "takefive",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "takefive",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1329"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devyanshi.takefive"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1329"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.devyanshi.takefive"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store"
    ]
  }
}
